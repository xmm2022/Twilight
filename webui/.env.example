# ============================================================
# Twilight Web UI 前端环境变量示例
# ------------------------------------------------------------
# 本地开发：复制为 .env.local 后按需修改。
# 生产部署：在 Cloudflare Pages/Workers Build 的 "Environment Variables"
# 里配置；或写入 wrangler.jsonc 的 "vars"（仅运行时生效）。
# ============================================================

# ---- 仅构建期可注入（NEXT_PUBLIC_*） ----
# 后端 API 基址。客户端组件在浏览器里直连此地址。
# 不设置时本地开发会通过 next.config.mjs 的 rewrites 代理到 BACKEND_URL（默认 localhost:5000）。
NEXT_PUBLIC_API_URL=https://your-twilight-backend.com

# 当 NEXT_PUBLIC_API_URL 为空时，Next.js rewrite 把 /api/* 代理到此地址
# Docker 部署时设为 twilight 服务名；本地开发默认 localhost:5000
BACKEND_URL=http://localhost:5000

# ---- 运行时可注入（无前缀，推荐用于经常调整的展示文案） ----
# 这些键在 Cloudflare Worker 启动时通过 wrangler.jsonc 的 "vars" 或运行时绑定提供，
# 由 `app/layout.tsx#generateMetadata` 每次请求时读取，改完即生效，无需重新构建。
SITE_NAME=Twilight Web
SITE_TITLE=Twilight Web
SITE_DESCRIPTION=Twilight Web
SITE_ICON=/favicon.png

# 登录/注册页普通文字颜色（CSS 颜色值，如 #333、white、rgba(255,255,255,0.9)）
# 留空则使用主题默认的 --foreground 颜色
# NEXT_PUBLIC_AUTH_TEXT_COLOR=#ffffff

# ---- 后端配置（通过 TWILIGHT_* 环境变量覆盖 config.toml） ----
# 登录页显示的控制面板图标，对应 config.toml [Global].server_icon
# TWILIGHT_SERVER_ICON=https://example.com/logo.png
# 登录/注册页背景图 URL，对应 config.toml [Global].auth_background_url
# TWILIGHT_AUTH_BACKGROUND_URL=/system/auth-background
