# ============================================================
#  Twilight 后端环境变量（精简版）
#  ------------------------------------------------------------
#  配置原则：除「后端监听地址 / 站点名称」等极少数部署级项目外，
#  其余所有配置一律放入 config.toml，不要写进 .env：
#    • 功能配置（数据库 / Emby / Telegram / 邮箱SMTP / 注册 / 限流 /
#      调度 / 安全 / Bangumi / TMDB 等）→ config.toml
#      （参考 config.production.toml；后台「系统配置」页可视化编辑并热重载）
#    • 敏感密钥（数据库密码 / Emby Token / Bot Token / bot_internal_secret 等）
#      → config.local.toml（同目录私密覆盖，不入库）
#
#  说明：TWILIGHT_* 环境变量仍可覆盖对应 config 字段（容器 / CI 等场景备用），
#  但默认部署请以 config.toml 为唯一配置源，不要在此堆叠功能开关。
#  前端展示项（后端 API 基址 / 站点名称 / 介绍 / 图标）见 webui/.env.example。
# ============================================================

# 后端监听地址（建议保留在 .env，便于容器 / 反向代理按环境调整）
TWILIGHT_API_HOST=0.0.0.0
TWILIGHT_API_PORT=5000

# 站点名称（也可改在 config.toml 的 [Global].server_name）
TWILIGHT_GLOBAL_SERVER_NAME=Twilight
